{
  "manifest_version": 3,
  "name": "ChatGPT 상세 질문 패널",
  "version": "0.5.0",
  "description": "선택 텍스트 우클릭으로 상세 질문, 또는 빈 페이지 우클릭으로 오늘 방문 기록을 백그라운드에서 ChatGPT에 요약 요청. 결과 완료 시 자동으로 패널이 펼쳐집니다.",
  "permissions": [
    "contextMenus",
    "scripting",
    "tabs",
    "history",
    "declarativeNetRequest",
    "storage",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT 상세 질문 (클릭: 알림 테스트)"
  },
  "commands": {
    "ask-detail-from-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "windows": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "선택한 텍스트로 상세 질문 패널 열기"
    },
    "test-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "windows": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "[테스트] 현재 보이는 탭 영역 캡처 후 다운로드 폴더에 저장"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "frame_unblock",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
